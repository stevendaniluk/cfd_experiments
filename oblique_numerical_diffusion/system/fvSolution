FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    s{
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-10;
        relTol          0.0;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors    0;
}

